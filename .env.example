APP_NAME="Employee Management"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173

# Cloud DB examples (use ONE connection):
#
# A) Neon (Postgres) — https://neon.tech  — copy connection string and map:
# DB_CONNECTION=pgsql
# DB_HOST=ep-xxxxx.region.aws.neon.tech
# DB_PORT=5432
# DB_DATABASE=neondb
# DB_USERNAME=neondb_owner
# DB_PASSWORD=secret
# DB_SSLMODE=require
#
# B) PlanetScale (MySQL) / any MySQL — https://planetscale.com
# DB_CONNECTION=mysql
# DB_HOST=aws.connect.psdb.cloud
# DB_PORT=3306
# DB_DATABASE=Laravel
# DB_USERNAME=root
# DB_PASSWORD=...
#
# C) Supabase (Postgres) — https://supabase.com
# same shape as (A) with the host and credentials from Project Settings
#
# Local / offline only (no online DB):
# DB_CONNECTION=sqlite
# and leave other DB_ vars empty

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

BROADCAST_DRIVER=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
MAIL_MAILER=log

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,localhost:5173,127.0.0.1:5173

VITE_APP_NAME="${APP_NAME}"
